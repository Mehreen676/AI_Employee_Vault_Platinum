# Core safety flag
DRY_RUN=false

# Optional OpenAI usage (legacy/gold flows)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_TASK_CHARS=6000

# MCP runtime
MCP_DRY_RUN=true
MCP_REGISTRY_AUTOLOAD=true
MCP_DEBUG=false

# Odoo integration (Platinum local executor -> odoo_client.py)
ODOO_URL=https://your-odoo-instance.example.com
ODOO_DB=your_odoo_database
ODOO_USERNAME=admin@example.com
# ODOO_USER is accepted as legacy fallback by odoo_client.py
ODOO_USER=
ODOO_PASSWORD=your_odoo_password_or_api_key
ODOO_TIMEOUT_S=30

# Gmail watcher credentials are file-based (not env vars):
# - credentials.json (required for live Gmail polling)
# - token.json (auto-generated after OAuth)
