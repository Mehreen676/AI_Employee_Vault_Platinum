    end

    GW  -->|"atomic rename vault/Needs_Action/email/"| NA
    SL  -->|"vault task Needs_Action/"| NA
    WA  -->|"vault task Needs_Action/"| NA
    VC  -->|"vault task Needs_Action/voice/"| NA
    MD  --> NA
    IB  --> NA
    NA  -->|"claim-by-move Path.rename() atomic OS lock"| CA
    CA  -->|"task manifest Pending_Approval/"| PA["Pending_Approval/\nawaiting human review"]

    class GW,SL,WA,VC,MD,IB,NA inputCls
    class CA,TP,PG cloudCls
    class PA vaultCls
